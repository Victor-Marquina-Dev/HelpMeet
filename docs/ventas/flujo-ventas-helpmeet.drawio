        <mxCell id="note2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;" value="🔒 Seguridad&#xa;─────────────────&#xa;• Key nunca se guarda en BD&#xa;• Se guarda SHA-256(key)&#xa;• JWT en Credential Manager&#xa;• Admin key con HMAC compare&#xa;• device_id también hasheado" vertex="1">
          <mxGeometry height="115" width="180" x="1560" y="940" as="geometry" />
        </mxCell>
        <mxCell id="note3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=10;" value="📧 Sin dominio verificado&#xa;─────────────────&#xa;Resend → solo a tu Gmail&#xa;Tú reenvías al cliente&#xa;&#xa;Con dominio (~$10/año):&#xa;Resend → directo al cliente" vertex="1">
