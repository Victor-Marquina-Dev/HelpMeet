        <mxCell id="note1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00b86b;strokeColor=#00703f;fontSize=11;fontColor=#ffffff;align=left;spacingLeft=10;" value="🔑 Generación de la clave&#xa;─────────────────&#xa;Módulo: secrets (Python)&#xa;Función: generate_license_key()&#xa;Formato: HM-XXXX-XXXX-XXXX-XXXX&#xa;Alfabeto: A-Z, 0-9&#xa;Solo se muestra UNA VEZ" vertex="1">
          <mxGeometry height="115" width="180" x="1560" y="800" as="geometry" />
