        <mxCell id="note4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" value="⚙️ Idempotencia&#xa;─────────────────&#xa;Cada sale_id de Gumroad&#xa;se guarda como evento.&#xa;Si Gumroad reenvía el&#xa;mismo webhook 2 veces,&#xa;NO se duplica la licencia." vertex="1">
