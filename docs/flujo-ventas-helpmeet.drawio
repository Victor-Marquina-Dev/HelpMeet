    <!-- NOTAS LATERALES -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <mxCell id="note1" value="🔑 Generación de la clave&#xa;─────────────────&#xa;Módulo: secrets (Python)&#xa;Función: generate_license_key()&#xa;Formato: HM-XXXX-XXXX-XXXX-XXXX&#xa;Alfabeto: A-Z, 0-9&#xa;Solo se muestra UNA VEZ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00b86b;strokeColor=#00703f;fontSize=11;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
      <mxGeometry x="1560" y="800" width="180" height="115" as="geometry" />
    </mxCell>

    <mxCell id="note2" value="🔒 Seguridad&#xa;─────────────────&#xa;• Key nunca se guarda en BD&#xa;• Se guarda SHA-256(key)&#xa;• JWT en Credential Manager&#xa;• Admin key con HMAC compare&#xa;• device_id también hasheado" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
      <mxGeometry x="1560" y="940" width="180" height="115" as="geometry" />
    </mxCell>

    <mxCell id="note3" value="📧 Sin dominio verificado&#xa;─────────────────&#xa;Resend → solo a tu Gmail&#xa;Tú reenvías al cliente&#xa;&#xa;Con dominio (~$10/año):&#xa;Resend → directo al cliente" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
      <mxGeometry x="1560" y="1140" width="180" height="115" as="geometry" />
    </mxCell>

    <mxCell id="note4" value="⚙️ Idempotencia&#xa;─────────────────&#xa;Cada sale_id de Gumroad&#xa;se guarda como evento.&#xa;Si Gumroad reenvía el&#xa;mismo webhook 2 veces,&#xa;NO se duplica la licencia." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
      <mxGeometry x="1560" y="630" width="180" height="115" as="geometry" />
    </mxCell>

