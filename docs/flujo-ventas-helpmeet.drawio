    <!-- Backend verifica si ya procesó -->
    <mxCell id="b2" value="¿Ya procesó este sale_id?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
