    </mxCell>

    <mxCell id="b5" value="🔒 Hashea la key&#xa;SHA-256(key) → key_hash&#xa;La key en texto plano&#xa;NUNCA se guarda en BD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="460" y="935" width="220" height="65" as="geometry" />
