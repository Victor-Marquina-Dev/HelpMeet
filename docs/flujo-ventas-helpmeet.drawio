    <!-- FASE 4: ACTIVACIÓN EN LA APP -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <!-- App abre pantalla de activación -->
    <mxCell id="app1" value="Abre Helpmeet&#xa;Pantalla 'Activa tu licencia'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
