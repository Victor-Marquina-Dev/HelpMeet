    </mxCell>

    <!-- NO — crea cliente -->
    <mxCell id="b3" value="Busca/crea Customer&#xa;en BD por email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="335" y="590" width="150" height="45" as="geometry" />
    </mxCell>

    <!-- GENERA LA KEY ← PUNTO CRÍTICO -->
    <mxCell id="b4" value="🔑 GENERA PRODUCT KEY&#xa;&#xa;generate_license_key()&#xa;secrets.choice(A-Z0-9)&#xa;Formato: HM-XXXX-XXXX-XXXX-XXXX&#xa;&#xa;Criptográficamente segura" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00CC66;strokeColor=#007A33;fontSize=11;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
      <mxGeometry x="325" y="650" width="170" height="90" as="geometry" />
    </mxCell>

    <!-- Hashea la key -->
    <mxCell id="b5" value="🔒 Hashea la key&#xa;SHA-256(key) → key_hash&#xa;Guarda solo el hash&#xa;La key NUNCA se almacena" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="335" y="755" width="150" height="65" as="geometry" />
    </mxCell>

    <!-- DB: guarda licencia -->
    <mxCell id="db1" value="INSERT License&#xa;─────────────&#xa;customer_id&#xa;key_hash (SHA-256)&#xa;key_last4 (XXXX)&#xa;plan = personal&#xa;status = active&#xa;max_devices = 1&#xa;created_at = NOW()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="575" y="650" width="160" height="130" as="geometry" />
    </mxCell>

    <!-- DB: guarda evento -->
    <mxCell id="db2" value="INSERT LicenseEvent&#xa;─────────────────&#xa;event_type: gumroad_purchase&#xa;metadata: {sale_id, email}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="575" y="795" width="160" height="65" as="geometry" />
    </mxCell>

    <!-- Backend notifica a Victor -->
    <mxCell id="b6" value="📧 Notifica a Victor&#xa;via Resend (HTTPS)&#xa;Con: email cliente + key" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="335" y="835" width="150" height="55" as="geometry" />
    </mxCell>

