      <mxGeometry x="50" y="775" width="110" height="60" as="geometry" />
    </mxCell>

    <!-- App llama al backend -->
    <mxCell id="app2" value="POST /api/license/activate&#xa;{license_key, device_id,&#xa; device_name, os, version}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
