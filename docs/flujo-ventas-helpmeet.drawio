      <mxGeometry x="770" y="545" width="160" height="60" as="geometry" />
    </mxCell>

    <!-- Backend genera nueva key para enviar -->
    <mxCell id="b7" value="POST /generate-key&#xa;Nueva key generada&#xa;Registra evento key_sent&#xa;Notifica a Victor con key" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="335" y="545" width="150" height="65" as="geometry" />
    </mxCell>

    <!-- Victor reenvía al cliente -->
