    <mxCell id="b1" value="Recibe webhook&#xa;Verifica token HMAC&#xa;✅ Autenticado" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="335" y="455" width="150" height="55" as="geometry" />
