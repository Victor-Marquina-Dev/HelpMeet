    <mxCell id="b4" value="🔑  GENERA LA PRODUCT KEY  🔑&#xa;&#xa;generate_license_key()&#xa;secrets.choice(A-Z0-9) × 16&#xa;Formato: HM-XXXX-XXXX-XXXX-XXXX&#xa;&#xa;Criptográficamente segura&#xa;(módulo 'secrets', no random)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00b86b;strokeColor=#00703f;fontSize=12;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
